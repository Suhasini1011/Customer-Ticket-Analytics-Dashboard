      <aliases enabled='yes' />
      <column caption='CSAT Category' datatype='string' name='[CSAT_Category]' role='dimension' type='nominal' />
      <column caption='CSAT Score' datatype='integer' name='[CSAT_Score]' role='measure' type='quantitative' />
      <column caption='SLA%' datatype='real' name='[Calculation_1529957287483453440]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SLA_Flag]) / COUNT([TicketID])' />
      </column>
      <column caption='COLOUR' datatype='string' name='[Calculation_1529957287486144514]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1529957287483453440] &lt; 0.4 THEN &quot;Low&quot;&#10;ELSEIF [Calculation_1529957287483453440] &lt; 0.6 THEN &quot;Medium&quot;&#10;ELSE &quot;High&quot;&#10;END' />
      </column>
      <column caption='Avg CSAT' datatype='real' name='[Calculation_1529957287514099715]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([CSAT_Score])' />
      </column>
      <column caption='Avg Resolution Time Hrs' datatype='real' name='[Calculation_1529957287516938244]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([ResolutionTimeHrs])' />
      </column>
      <column caption='CSAT Result' datatype='string' name='[Calculation_1529957287518494725]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([CSAT_Score]) &gt;= 4 THEN &quot;Good&quot;&#10;ELSE &quot;Needs Improvement&quot;&#10;END' />
      </column>
      <column caption='Resolution Result' datatype='string' name='[Calculation_1529957287518973958]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([ResolutionTimeHrs]) &gt; 12 THEN &quot;High&quot;&#10;ELSE &quot;Optimal&quot;&#10;END' />
      </column>
      <column caption='SLA status' datatype='string' name='[Calculation_1529957287571021831]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1529957287483453440] &lt; 0.5 THEN &quot;Below Target&quot;&#10;ELSE &quot;On Track&quot;&#10;END' />
      </column>
      <column caption='Created Date' datatype='datetime' name='[CreatedDate]' role='dimension' type='ordinal' />
      <column caption='Resolution Time Hrs' datatype='real' name='[ResolutionTimeHrs]' role='measure' type='quantitative' />
